# Stripe secret key — find at dashboard.stripe.com/apikeys
# Use sk_test_... for development, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_...

# Your deployed site URL (no trailing slash) — used for Stripe redirect URLs
SITE_URL=https://your-project.vercel.app

# Optional: Nonprofit details
PUBLIC_NONPROFIT_NAME=Your Nonprofit Name
PUBLIC_NONPROFIT_EIN=XX-XXXXXXX
PUBLIC_NONPROFIT_TAGLINE=Empowering communities through technology

# Social media profile URLs (leave empty to hide)
PUBLIC_SOCIAL_FACEBOOK=
PUBLIC_SOCIAL_X=
PUBLIC_SOCIAL_INSTAGRAM=
PUBLIC_SOCIAL_LINKEDIN=
PUBLIC_SOCIAL_BLUESKY=
