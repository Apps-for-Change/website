---
interface Props {
  name: string;
  description: string;
  icon: string;
  appleUrl?: string;
  googleUrl?: string;
}

const { name, description, icon, appleUrl, googleUrl } = Astro.props;
---

<article class="bg-(--color-card) rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col items-center text-center hover:shadow-md transition-shadow">
  <img
    src={icon}
    alt={`${name} app icon`}
    class="w-20 h-20 rounded-2xl mb-4"
    width="80"
    height="80"
  />
  <h3 class="text-xl font-bold text-(--color-text) mb-2">{name}</h3>
  <p class="text-(--color-text-secondary) mb-6 flex-1">{description}</p>
  <div class="flex flex-wrap gap-3 justify-center">
    {appleUrl && (
      <a href={appleUrl} target="_blank" rel="noopener noreferrer" aria-label={`Download ${name} on the App Store`} class="inline-flex items-center gap-2 bg-(--color-primary) text-white px-4 py-2 rounded-full text-sm font-semibold hover:bg-(--color-primary-light) transition-colors">
        <img src="/images/apple-app-store.png" alt="" class="w-5 h-5 rounded-full" width="20" height="20" />
        App Store
      </a>
    )}
    {googleUrl && (
      <a href={googleUrl} target="_blank" rel="noopener noreferrer" aria-label={`Get ${name} on Google Play`} class="inline-flex items-center gap-2 bg-(--color-primary) text-white px-4 py-2 rounded-full text-sm font-semibold hover:bg-(--color-primary-light) transition-colors">
        <img src="/images/google-play-store.jpg" alt="" class="w-5 h-5 rounded-full" width="20" height="20" />
        Google Play
      </a>
    )}
  </div>
</article>
