---
const name = import.meta.env.PUBLIC_NONPROFIT_NAME || "Apps for Change";
const hasStripe = !!import.meta.env.STRIPE_SECRET_KEY;
const donateUrl = import.meta.env.PUBLIC_STRIPE_DONATE_URL;
const hasStripeLink = donateUrl && donateUrl !== "https://donate.stripe.com/your-link-here";
const wpDonateBase = "https://appsforchange.org/?membershipId=2028";

const frequencies = [
  { id: "onetime", label: "One-time" },
  { id: "monthly", label: "Monthly" },
  { id: "annual",  label: "Annual"  },
];

const presets = [10, 25, 50, 100];
---

<section id="donate" class="py-16 sm:py-20 lg:py-24 bg-(--color-primary) text-white">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl mb-4" style="font-family: 'Young Serif', serif;">Donations</h2>
    <p class="text-lg text-white/85 mb-10 max-w-xl mx-auto">
      Your donation helps us keep our apps free on the App Store and Google Play, ensuring that everyone who needs them can access and use them at no cost.
    </p>

    {hasStripeLink ? (
      <a
        href={donateUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-(--color-accent) hover:bg-(--color-accent-hover) text-(--color-primary) font-bold text-lg px-10 py-4 rounded-full transition-colors shadow-lg"
      >
        Donate Now
      </a>
    ) : (
      <div class="max-w-md mx-auto">
        <div class="flex flex-wrap justify-center gap-3 mb-6">
          <a href={`${wpDonateBase}&plan=234`} target="_blank" rel="noopener noreferrer" class="bg-(--color-accent) hover:bg-(--color-accent-hover) text-(--color-primary) font-bold px-6 py-3 rounded-full transition-colors">$5</a>
          <a href={`${wpDonateBase}&plan=234`} target="_blank" rel="noopener noreferrer" class="bg-(--color-accent) hover:bg-(--color-accent-hover) text-(--color-primary) font-bold px-6 py-3 rounded-full transition-colors">$15</a>
          <a href={`${wpDonateBase}&plan=234`} target="_blank" rel="noopener noreferrer" class="bg-(--color-accent) hover:bg-(--color-accent-hover) text-(--color-primary) font-bold px-6 py-3 rounded-full transition-colors">$100</a>
        </div>
        <p class="text-white/60 text-sm">One-time donation. Monthly and yearly options available.</p>
      </div>
    )}

    <div class="flex items-center justify-center gap-6 mt-8 text-sm text-white/60">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <span>Secure payment</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
        <span>100% goes to our mission</span>
      </div>
    </div>

    {hasStripe ? (
      <div id="donate-widget">
        <!-- Frequency toggle -->
        <div class="inline-flex bg-white/10 rounded-lg p-1 mb-6">
          {frequencies.map((freq, i) => (
            <button
              data-freq={freq.id}
              class:list={[
                "freq-btn font-semibold px-5 py-2 rounded-md transition-colors",
                i === 0 ? "bg-white/20 text-white" : "text-white/70 hover:text-white",
              ]}
            >
              {freq.label}
            </button>
          ))}
        </div>

        <!-- Preset amounts -->
        <div class="flex flex-wrap justify-center gap-3 mb-4">
          {presets.map(amount => (
            <button
              data-amount={amount}
              class="preset-btn bg-white/20 hover:bg-white/30 text-white font-semibold px-6 py-3 rounded-lg transition-colors"
            >
              ${amount}
            </button>
          ))}
        </div>

        <!-- Custom amount -->
        <div class="flex items-center justify-center gap-3 mb-6">
          <label for="custom-amount" class="text-white/80 font-medium sr-only">Custom amount</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-white/60 pointer-events-none">$</span>
            <input
              id="custom-amount"
              type="number"
              min="1"
              step="1"
              placeholder="Custom amount"
              class="bg-white/20 text-white placeholder-white/50 pl-7 pr-4 py-3 rounded-lg w-44 focus:outline-none focus:ring-2 focus:ring-white/50"
            />
          </div>
        </div>

        <button
          id="donate-btn"
          class="inline-block bg-(--color-accent) hover:bg-(--color-accent-hover) text-white font-bold text-lg px-10 py-4 rounded-lg transition-colors shadow-lg disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Donate Now
        </button>
        <p id="donate-error" class="mt-3 text-red-200 text-sm hidden"></p>
      </div>

      <script>
        const freqBtns   = document.querySelectorAll<HTMLButtonElement>('.freq-btn');
        const presetBtns = document.querySelectorAll<HTMLButtonElement>('.preset-btn');
        const customInput = document.getElementById('custom-amount') as HTMLInputElement;
        const donateBtn  = document.getElementById('donate-btn') as HTMLButtonElement;
        const errorEl    = document.getElementById('donate-error') as HTMLElement;

        const freqLabels: Record<string, string> = {
          onetime: 'Donate Now',
          monthly: 'Donate Monthly',
          annual:  'Donate Annually',
        };

        let selectedFreq   = 'onetime';
        let selectedAmount = 0;

        freqBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            selectedFreq = btn.dataset.freq!;
            freqBtns.forEach(b => {
              b.classList.remove('bg-white/20', 'text-white');
              b.classList.add('text-white/70');
            });
            btn.classList.add('bg-white/20', 'text-white');
            btn.classList.remove('text-white/70');
            donateBtn.textContent = freqLabels[selectedFreq];
          });
        });

        presetBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            selectedAmount = Number(btn.dataset.amount);
            customInput.value = '';
            presetBtns.forEach(b => b.classList.remove('bg-white/40', 'ring-2', 'ring-white'));
            btn.classList.add('bg-white/40', 'ring-2', 'ring-white');
          });
        });

        customInput.addEventListener('input', () => {
          selectedAmount = Number(customInput.value);
          presetBtns.forEach(b => b.classList.remove('bg-white/40', 'ring-2', 'ring-white'));
        });

        donateBtn.addEventListener('click', async () => {
          errorEl.classList.add('hidden');

          if (!selectedAmount || selectedAmount < 1) {
            errorEl.textContent = 'Please select or enter a donation amount (minimum $1).';
            errorEl.classList.remove('hidden');
            return;
          }

          donateBtn.disabled = true;
          donateBtn.textContent = 'Redirecting…';

          try {
            const res = await fetch('/api/checkout', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ amount: selectedAmount, frequency: selectedFreq }),
            });
            const data = await res.json();

            if (data.url) {
              window.location.href = data.url;
            } else {
              throw new Error(data.error || 'Something went wrong. Please try again.');
            }
          } catch (err: any) {
            errorEl.textContent = err.message;
            errorEl.classList.remove('hidden');
            donateBtn.disabled = false;
            donateBtn.textContent = freqLabels[selectedFreq];
          }
        });
      </script>
    ) : (
      <div class="bg-white/10 rounded-lg p-6 max-w-md mx-auto">
        <p class="text-white/90 font-semibold mb-2">Donation coming soon</p>
        <p class="text-white/60 text-sm">
          Site owner: set the <code class="bg-white/10 px-1.5 py-0.5 rounded">STRIPE_SECRET_KEY</code> environment variable to enable donations.
        </p>
      </div>
    )}

    <p class="mt-6 text-sm text-white/50">
      {name} is a registered 501(c)(3) nonprofit. Your donation may be tax deductible.
    </p>
  </div>
</section>
