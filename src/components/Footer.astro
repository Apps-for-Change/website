---
import ShareButtons from "./ShareButtons.astro";
const year = new Date().getFullYear();
const name = "Apps for Change";
const ein = import.meta.env.PUBLIC_NONPROFIT_EIN || "XX-XXXXXXX";
---

<footer class="bg-(--color-primary) text-gray-400 py-12">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 mb-8">
      <div>
        <h3 class="text-white font-bold text-lg mb-3">{name}</h3>
        <p class="text-sm">EIN: {ein}</p>
        <p class="text-sm mt-1">A 501(c)(3) nonprofit organization</p>
        <div class="mt-4">
          <ShareButtons
            label="Share this page"
            labelClass="text-white font-semibold text-sm"
            linkClass="text-gray-400 hover:text-white transition-colors"
            class="flex-col items-start gap-2"
          />
        </div>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-3 text-sm">Address</h3>
        <p class="text-sm">1670 S Robert Street</p>
        <p class="text-sm">#131</p>
        <p class="text-sm">West Saint Paul, MN 55118</p>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-3 text-sm">Menu</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><a href="/about" class="hover:text-white transition-colors">About us</a></li>
          <li><a href="/get-involved" class="hover:text-white transition-colors">Get involved</a></li>
          <li><a href="/#apps" class="hover:text-white transition-colors">Our apps</a></li>
          <li><a href="/#donate" class="hover:text-white transition-colors">Donate</a></li>
          <li><a href="mailto:info@appsforchange.org" class="hover:text-white transition-colors">Contact us</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-700 pt-8 text-center text-sm">
      <p>&copy; {year} Apps for Change. All rights reserved.</p>
    </div>
  </div>
</footer>
