---
const year = new Date().getFullYear();
const name = "Apps for Change";
const ein = import.meta.env.PUBLIC_NONPROFIT_EIN || "XX-XXXXXXX";

const socials = [
  { name: "Facebook", url: import.meta.env.PUBLIC_SOCIAL_FACEBOOK, icon: "facebook" },
  { name: "X", url: import.meta.env.PUBLIC_SOCIAL_X, icon: "x" },
  { name: "Instagram", url: import.meta.env.PUBLIC_SOCIAL_INSTAGRAM, icon: "instagram" },
  { name: "LinkedIn", url: import.meta.env.PUBLIC_SOCIAL_LINKEDIN, icon: "linkedin" },
  { name: "Bluesky", url: import.meta.env.PUBLIC_SOCIAL_BLUESKY, icon: "bluesky" },
].filter(s => s.url);
---

<footer class="bg-(--color-primary) text-gray-400 py-12">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 mb-8">
      <div>
        <h3 class="text-white font-bold text-lg mb-3">{name}</h3>
        <p class="text-sm">EIN: {ein}</p>
        <p class="text-sm mt-1">A 501(c)(3) nonprofit organization</p>
        {socials.length > 0 && (
          <div class="flex gap-3 mt-4">
            {socials.map(s => (
              <a href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.name} class="text-gray-400 hover:text-white transition-colors">
                {s.icon === "facebook" && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                )}
                {s.icon === "x" && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>
                )}
                {s.icon === "instagram" && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069ZM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0Zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324ZM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881Z"/></svg>
                )}
                {s.icon === "linkedin" && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286ZM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065Zm1.782 13.019H3.555V9h3.564v11.452ZM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003Z"/></svg>
                )}
                {s.icon === "bluesky" && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.785 2.627 3.6 3.476 6.153 3.13-4.4.595-8.239 2.451-3.853 7.144C7.586 25.325 10.655 20.063 12 17.159c1.345 2.904 4.36 8.107 9.076 3.362 4.386-4.693.547-6.55-3.853-7.144 2.553.346 5.368-.503 6.153-3.13.246-.828.624-5.789.624-6.478 0-.69-.139-1.861-.902-2.206-.659-.298-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8Z"/></svg>
                )}
              </a>
            ))}
          </div>
        )}
      </div>

      <div>
        <h3 class="text-white font-semibold mb-3 text-sm">Address</h3>
        <p class="text-sm">1670 S Robert Street</p>
        <p class="text-sm">#131</p>
        <p class="text-sm">West Saint Paul, MN 55118</p>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-3 text-sm">Menu</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="https://appsforchange.org/" class="hover:text-white transition-colors">Home</a></li>
          <li><a href="https://appsforchange.org/about/" class="hover:text-white transition-colors">About us</a></li>
          <li><a href="https://appsforchange.org/get-involved/" class="hover:text-white transition-colors">Get involved</a></li>
          <li><a href="https://appsforchange.org/apps/" class="hover:text-white transition-colors">Our apps</a></li>
          <li><a href="https://appsforchange.org/contact/" class="hover:text-white transition-colors">Contact us</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-700 pt-8 text-center text-sm">
      <p>&copy; {year} Apps for Change. All rights reserved.</p>
    </div>
  </div>
</footer>
