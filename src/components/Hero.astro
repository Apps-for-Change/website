---
---

<section class="relative bg-(--color-bg) py-16 sm:py-20 lg:py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center gap-10 lg:gap-16">
      <div class="md:w-1/2">
        <img
          src="/images/afc-logo.png"
          alt="Apps for Change logo"
          class="w-full max-w-md mx-auto"
          width="1024"
          height="1024"
          style="aspect-ratio: 3/4; object-fit: cover;"
          fetchpriority="high"
        />
      </div>
      <div class="md:w-1/2">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl text-(--color-text) mb-6" style="font-family: 'Young Serif', serif;">
          Driving Meaningful Change, One App at a Time.
        </h2>
        <p class="text-lg text-(--color-text-secondary) mb-8">
          We are here to help. Have an app idea? Send it our way and we can work together to build it. Apps built by the community, for the community. Self-help, help others, let us help you make your idea come to life. Download one of our apps today and start using them. They're free, always.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="#apps"
            class="inline-block bg-(--color-primary) text-white font-semibold px-8 py-3 rounded-full hover:bg-(--color-primary-light) transition-colors text-center"
          >
            Explore Our Apps
          </a>
          <a
            href="#donate"
            class="inline-block bg-(--color-accent) hover:bg-(--color-accent-hover) text-(--color-primary) font-semibold px-8 py-3 rounded-full transition-colors text-center"
          >
            Support Our Mission
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
