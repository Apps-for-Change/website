---
interface Props {
  author: string;
  rating: number;
  title: string;
  text: string;
  store: "apple" | "google";
  date: string;
}

const { author, rating, title, text, store, date } = Astro.props;

const displayText = text.length > 200 ? text.slice(0, 200) + "\u2026" : text;

const formattedDate = new Date(date).toLocaleDateString("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
---

<article class="bg-(--color-card) rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col">
  <div class="flex items-center gap-1 mb-2" aria-label={`${rating} out of 5 stars`}>
    {Array.from({ length: 5 }).map((_, i) => (
      <svg
        class={`w-5 h-5 ${i < rating ? "text-(--color-star)" : "text-gray-300"}`}
        fill="currentColor"
        viewBox="0 0 20 20"
        aria-hidden="true"
      >
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>

  {title && <h3 class="font-semibold text-(--color-text) mb-1">{title}</h3>}
  <p class="text-(--color-text-secondary) text-sm flex-1 mb-4">{displayText}</p>

  <div class="flex items-center justify-between text-xs text-(--color-text-secondary)">
    <div class="flex items-center gap-2">
      {store === "apple" ? (
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-label="Apple App Store">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
        </svg>
      ) : (
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-label="Google Play Store">
          <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-1.4l2.651 1.535a1 1 0 010 1.733l-2.758 1.595-2.527-2.527 2.634-2.336zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z" />
        </svg>
      )}
      <span class="font-medium">{author}</span>
    </div>
    <time datetime={date}>{formattedDate}</time>
  </div>
</article>
