---
interface Props {
  author: string;
  rating: number;
  title: string;
  text: string;
  store: "apple" | "google";
  date: string;
}

const { author, rating, title, text, store, date } = Astro.props;

const displayText = text.length > 200 ? text.slice(0, 200) + "\u2026" : text;

const storeIcon = store === "apple"
  ? "/images/apple-app-store.png"
  : "/images/google-play-store.jpg";

const formattedDate = new Date(date).toLocaleDateString("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
---

<article class="bg-(--color-card) rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col">
  <div class="flex items-center gap-3 mb-4">
    <img src={storeIcon} alt={`${store === "apple" ? "Apple App Store" : "Google Play Store"}`} class="w-10 h-10 rounded-full" width="40" height="40" />
    <div>
      <h3 class="font-semibold text-(--color-text) text-sm">{author}</h3>
      <time class="text-xs text-(--color-text-secondary)" datetime={date}>{formattedDate}</time>
    </div>
  </div>

  <div class="flex items-center gap-1 mb-3" aria-label={`${rating} out of 5 stars`}>
    {Array.from({ length: 5 }).map((_, i) => (
      <svg
        class={`w-4 h-4 ${i < rating ? "text-(--color-star)" : "text-gray-300"}`}
        fill="currentColor"
        viewBox="0 0 20 20"
        aria-hidden="true"
      >
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>

  {title && <h4 class="font-semibold text-(--color-text) mb-1 text-sm">{title}</h4>}
  <p class="text-(--color-text-secondary) text-sm flex-1">{displayText}</p>
</article>
