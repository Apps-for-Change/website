---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Get Involved"
  description="Volunteer, test apps, join town halls, or share an idea. Apps for Change is built with the communities we serve."
>
  <Navbar />
  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <h1 class="text-3xl sm:text-4xl mb-2">Get Involved</h1>
    <p class="text-(--color-text-secondary) mb-8">The best ideas come from the communities we serve.</p>

    <section class="mb-10">
      <h2 class="text-xl sm:text-2xl mb-3">Volunteer With Us</h2>
      <p class="mb-3">
        Apps for Change invites community members to contribute time, share skills, and help testers pilot new features in real-world settings. Whether you have thirty minutes or thirty hours a month, there's a way to help.
      </p>
      <p class="mb-3"><strong>Ways to contribute:</strong></p>
      <ul class="list-disc pl-6 space-y-1">
        <li>Beta testing new app features</li>
        <li>Participating in feedback sessions</li>
        <li>Content moderation</li>
        <li>Outreach to underrepresented communities</li>
        <li>Design, development, writing, organizing, and data analysis support</li>
      </ul>
    </section>

    <section class="mb-10">
      <h2 class="text-xl sm:text-2xl mb-3">Monthly Town Halls</h2>
      <p class="mb-3">
        Each month we host an open forum where community input directly shapes the apps we build. These sessions include previews of upcoming features, conversations with the development team, and real decisions driven by the people using our tools.
      </p>
      <p>
        Email us at <a href="mailto:info@appsforchange.org" class="text-(--color-accent) hover:underline">info@appsforchange.org</a> to request the next town hall date and the link to join.
      </p>
    </section>

    <section class="mb-10">
      <h2 class="text-xl sm:text-2xl mb-3">Share an App Idea</h2>
      <p>
        Have an idea for an app that could help your community? We'd love to hear it. Send it to <a href="mailto:info@appsforchange.org" class="text-(--color-accent) hover:underline">info@appsforchange.org</a> and we'll follow up within 48 hours. The best ideas in our library started exactly this way.
      </p>
    </section>

    <section class="mb-10">
      <h2 class="text-xl sm:text-2xl mb-3">Support the Mission Financially</h2>
      <p>
        Donations keep our apps free on the App Store and Google Play so anyone who needs them can use them. Visit the <a href="/#donate" class="text-(--color-accent) hover:underline">donation section</a> to give a one-time, monthly, or yearly gift. Apps for Change is a registered 501(c)(3), so your donation may be tax deductible.
      </p>
    </section>

    <section class="mb-10">
      <h2 class="text-xl sm:text-2xl mb-3">Contact</h2>
      <address class="not-italic leading-relaxed">
        <strong>Apps for Change</strong><br />
        Email: <a href="mailto:info@appsforchange.org" class="text-(--color-accent) hover:underline">info@appsforchange.org</a> (48-hour response)<br />
        1670 S Robert Street #131<br />
        West Saint Paul, MN 55118
      </address>
    </section>

    <p class="text-center text-(--color-text-secondary) italic mt-12">Apps for Change — Empowering Everyday People Through Technology</p>
  </main>
  <Footer />
</BaseLayout>
